generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum MeasurementUnit {
  EACH
  PACK
  TIN
  JAR
  LOAF
  GRAM
  KILOGRAM
  MILLILITRE
  LITRE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum SourceStatus {
  ACTIVE
  DISABLED
  REQUIRES_CONFIGURATION
  FAILING
}

enum PriceEntryMethod {
  MANUAL
  CSV_IMPORT
  AUTOMATED
}

enum MatchStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CollectionRunStatus {
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  SKIPPED
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  role                    UserRole                 @default(ADMIN)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  sessions                Session[]
  settings                UserSettings?
  stores                  Store[]
  mealPlans               MealPlan[]
  groceryRequirements     GroceryRequirement[]
  productCategories       ProductCategory[]
  products                Product[]
  shoppingLists           ShoppingList[]
  priceSources            PriceSource[]
  priceObservations       PriceObservation[]
  priceCollectionRuns     PriceCollectionRun[]
  notificationPreferences NotificationPreference[]
  pushSubscriptions       PushSubscription[]
  auditLogs               AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model UserSettings {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  householdSize              Int      @default(2)
  homeAddress                String
  maxStoreDistanceKm         Decimal  @db.Decimal(8, 2)
  avoidAucklandCbd           Boolean  @default(true)
  timezone                   String   @default("Pacific/Auckland")
  currency                   String   @default("NZD")
  fuelEconomyLitresPer100Km  Decimal  @db.Decimal(8, 2)
  fuelPriceCentsPerLitre     Int
  minimumSavingExtraStopCents Int
  woolworthsRewards          Boolean  @default(true)
  newWorldClubcard           Boolean  @default(true)
  costcoMembership           Boolean  @default(false)
  notificationsEnabled       Boolean  @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupermarketChain {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]
}

model Store {
  id                      String             @id @default(cuid())
  userId                  String
  chainId                 String
  branchName              String
  address                 String
  latitude                Decimal?           @db.Decimal(10, 7)
  longitude               Decimal?           @db.Decimal(10, 7)
  oneWayDistanceKm        Decimal?           @db.Decimal(8, 2)
  estimatedTravelMinutes  Int?
  active                  Boolean            @default(true)
  directionNotes          String?
  insidePreferredArea     Boolean            @default(true)
  requiresVerification    Boolean            @default(true)
  lastVerifiedAt          DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  chain                   SupermarketChain   @relation(fields: [chainId], references: [id])
  storeProducts           StoreProduct[]
  shoppingListItems       ShoppingListItem[]

  @@unique([userId, chainId, branchName])
  @@index([userId, active])
  @@index([chainId])
}

model MealPlan {
  id        String        @id @default(cuid())
  userId    String
  name      String
  startsOn  DateTime?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  days      MealPlanDay[]

  @@index([userId, active])
}

model MealPlanDay {
  id         String   @id @default(cuid())
  mealPlanId String
  dayOfWeek  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  meals      Meal[]

  @@unique([mealPlanId, dayOfWeek])
}

model Meal {
  id            String      @id @default(cuid())
  mealPlanDayId String
  type          MealType
  title         String
  servings      Int         @default(2)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  day           MealPlanDay @relation(fields: [mealPlanDayId], references: [id], onDelete: Cascade)
  ingredients   Ingredient[]

  @@index([mealPlanDayId, type])
}

model Ingredient {
  id                   String              @id @default(cuid())
  mealId               String
  groceryRequirementId String?
  name                 String
  quantity             Decimal             @db.Decimal(12, 3)
  unit                 MeasurementUnit
  notes                String?
  contributesToList    Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  meal                 Meal                @relation(fields: [mealId], references: [id], onDelete: Cascade)
  groceryRequirement   GroceryRequirement? @relation(fields: [groceryRequirementId], references: [id], onDelete: SetNull)

  @@index([groceryRequirementId])
}

model ProductCategory {
  id                  String               @id @default(cuid())
  userId              String
  name                String
  slug                String
  comparableUnit      MeasurementUnit
  acceptableTerms     Json                 @default("[]")
  excludedTerms       Json                 @default("[]")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  products            Product[]
  groceryRequirements GroceryRequirement[]

  @@unique([userId, slug])
}

model GroceryRequirement {
  id                       String             @id @default(cuid())
  userId                   String
  categoryId               String
  slug                     String
  name                     String
  requiredQuantity         Decimal            @db.Decimal(12, 3)
  requiredUnit             MeasurementUnit
  weeklyQuantityEditable   Boolean            @default(true)
  alreadyOwnedQuantity     Decimal            @default(0) @db.Decimal(12, 3)
  alreadyOwnedUnit         MeasurementUnit?
  substitutionNotes        String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category                 ProductCategory    @relation(fields: [categoryId], references: [id])
  ingredients              Ingredient[]
  shoppingListItems        ShoppingListItem[]

  @@unique([userId, slug])
  @@index([categoryId])
}

model Product {
  id              String           @id @default(cuid())
  userId          String
  categoryId      String
  canonicalName   String
  brand           String?
  packageQuantity Decimal          @db.Decimal(12, 3)
  packageUnit     MeasurementUnit
  productUrl      String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        ProductCategory  @relation(fields: [categoryId], references: [id])
  aliases         ProductAlias[]
  storeProducts   StoreProduct[]

  @@index([userId, categoryId])
}

model ProductAlias {
  id        String      @id @default(cuid())
  productId String
  alias     String
  status    MatchStatus @default(APPROVED)
  reason    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, alias])
}

model StoreProduct {
  id                String             @id @default(cuid())
  storeId           String
  productId         String
  supermarketSku    String?
  supermarketName   String
  productUrl        String?
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  store             Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceObservations PriceObservation[]
  shoppingListItems ShoppingListItem[]

  @@unique([storeId, productId, supermarketName])
  @@index([storeId])
  @@index([productId])
}

model PriceObservation {
  id                    String           @id @default(cuid())
  userId                String
  storeProductId        String
  priceSourceId         String
  normalPriceCents      Int
  loyaltyPriceCents     Int?
  requiresLoyaltyCard   Boolean          @default(false)
  specialStart          DateTime?
  specialEnd            DateTime?
  collectedAt           DateTime
  sourceConfidence      Decimal          @default(1.00) @db.Decimal(4, 2)
  entryMethod           PriceEntryMethod
  originalSource        String?
  notes                 String?
  stale                 Boolean          @default(false)
  createdAt             DateTime         @default(now())
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeProduct          StoreProduct     @relation(fields: [storeProductId], references: [id], onDelete: Cascade)
  priceSource           PriceSource      @relation(fields: [priceSourceId], references: [id])

  @@index([userId, collectedAt])
  @@index([storeProductId, collectedAt])
  @@index([priceSourceId])
}

model ShoppingList {
  id             String             @id @default(cuid())
  userId         String
  name           String
  weekStartsOn   DateTime
  status         String             @default("active")
  groceryCents   Int                @default(0)
  fuelCents      Int                @default(0)
  totalCents     Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          ShoppingListItem[]

  @@index([userId, weekStartsOn])
}

model ShoppingListItem {
  id                    String              @id @default(cuid())
  shoppingListId        String
  groceryRequirementId  String
  selectedStoreProductId String?
  storeId               String?
  requiredQuantity      Decimal             @db.Decimal(12, 3)
  requiredUnit          MeasurementUnit
  packsNeeded           Int                 @default(0)
  leftoverQuantity      Decimal             @default(0) @db.Decimal(12, 3)
  unitPriceCents        Int?
  effectivePriceCents   Int?
  requiresLoyaltyCard   Boolean             @default(false)
  purchased             Boolean             @default(false)
  alreadyOwned          Boolean             @default(false)
  rejectedProductIds    Json                @default("[]")
  lastCheckedAt         DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  shoppingList          ShoppingList         @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  groceryRequirement    GroceryRequirement  @relation(fields: [groceryRequirementId], references: [id])
  selectedStoreProduct  StoreProduct?        @relation(fields: [selectedStoreProductId], references: [id])
  store                 Store?              @relation(fields: [storeId], references: [id])

  @@index([shoppingListId])
  @@index([groceryRequirementId])
}

model PriceSource {
  id                    String               @id @default(cuid())
  userId                String
  name                  String
  slug                  String
  status                SourceStatus         @default(DISABLED)
  adapterKey            String
  documentationUrl      String?
  lastSuccessfulRunAt   DateTime?
  lastError             String?
  enabled               Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  observations          PriceObservation[]
  collectionRuns        PriceCollectionRun[]

  @@unique([userId, slug])
}

model PriceCollectionRun {
  id             String              @id @default(cuid())
  userId         String
  priceSourceId  String?
  status         CollectionRunStatus @default(RUNNING)
  startedAt      DateTime            @default(now())
  endedAt        DateTime?
  productsChecked Int                @default(0)
  pricesAdded    Int                 @default(0)
  warnings       Json                @default("[]")
  errors         Json                @default("[]")
  lockKey        String?
  createdAt      DateTime            @default(now())
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceSource    PriceSource?        @relation(fields: [priceSourceId], references: [id])

  @@index([userId, startedAt])
  @@index([status])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String
  pricesUpdated         Boolean  @default(false)
  priceDropThresholdCents Int?
  missingPriceWarning   Boolean  @default(true)
  stalePriceWarning     Boolean  @default(true)
  weeklyListReady       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth      String
  userAgent String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  ipHash    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entity, entityId])
}
